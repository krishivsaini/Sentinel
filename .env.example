# Copy to .env and fill in. .env is gitignored — never commit real values.
# Only two secrets are needed; embedding + reranker models run locally at ₹0.

# --- Gemini (generation step + Ragas judge only) ---
# Free-tier key from https://aistudio.google.com/apikey
# NOTE: free-tier per-model RPM/RPD are project-specific and were cut 50–80% in Dec 2025 —
# confirm your live quota at https://aistudio.google.com/rate-limit before a full eval run.
GOOGLE_API_KEY=

# --- JWT auth for the /query endpoint (single demo user — §11) ---
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SENTINEL_JWT_SECRET=

# --- Demo user credentials (the only account; not multi-tenant — out of scope §1.3) ---
SENTINEL_DEMO_USER=demo
SENTINEL_DEMO_PASSWORD=change-me

# --- Optional overrides (defaults live in sentinel/config.py) ---
# SENTINEL_GENERATION_MODEL=gemini-3.5-flash
# SENTINEL_FAITHFULNESS_THRESHOLD=0.80
