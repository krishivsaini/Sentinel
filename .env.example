# Copy to .env and fill in. .env is gitignored — never commit real values.
# The embedding + reranker models run locally at ₹0; only the LLM calls need a key.

# --- Groq (product generation + Ragas judge) — the default provider ---
# Free key (no credit card) from https://console.groq.com/keys
# Chosen because Gemini's free tier caps at ~20 requests/day/model — far too few for the eval
# or the CI gate — whereas Groq's free tier gives llama-3.3-70b ~1,000 requests/day.
GROQ_API_KEY=

# --- Gemini (alternate LLM provider; only if you switch *_PROVIDER back to "google") ---
# Free-tier key from https://aistudio.google.com/apikey. Optional — leave blank when using Groq.
GOOGLE_API_KEY=

# --- JWT auth for the /query endpoint (single demo user — §11) ---
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SENTINEL_JWT_SECRET=

# --- Demo user credentials (the only account; not multi-tenant — out of scope §1.3) ---
SENTINEL_DEMO_USER=demo
SENTINEL_DEMO_PASSWORD=change-me

# --- Optional overrides (defaults live in sentinel/config.py) ---
# SENTINEL_GENERATION_PROVIDER=groq
# SENTINEL_GENERATION_MODEL=llama-3.3-70b-versatile
# SENTINEL_JUDGE_MODEL=llama-3.3-70b-versatile
# SENTINEL_FAITHFULNESS_THRESHOLD=0.80
